generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Tier {
  FREE
  PRO
}

enum Units {
  IMPERIAL
  METRIC
}

enum CollabRole {
  EDITOR
  VIEWER
}

enum SunLevel {
  FULL_SUN
  PARTIAL_SUN
  PARTIAL_SHADE
  FULL_SHADE
}

enum WaterNeed {
  LOW
  MODERATE
  HIGH
}

enum PlantCategory {
  VEGETABLE
  FRUIT
  HERB
  FLOWER
  TREE
  SHRUB
  OTHER
}

enum CompanionType {
  BENEFICIAL
  HARMFUL
}

enum PlantingStatus {
  PLANNED
  SEEDS_STARTED
  TRANSPLANTED
  ACTIVE
  HARVESTING
  HARVESTED
  FAILED
}

// How a planting gets into the ground — drives the calendar/reminder timing.
// Null means "not chosen yet; use the recommended method for the season".
enum PlantStartMethod {
  SEED_INDOORS
  DIRECT_SOW
  BUY_START
}

enum ReminderType {
  START_SEEDS
  TRANSPLANT
  FERTILIZE
  WATER
  HARVEST
  FROST_ALERT
  SUCCESSION_PLANTING
  CROP_ROTATION
  CUSTOM
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id                   String    @id // Clerk user ID
  email                String    @unique
  name                 String?
  avatarUrl            String?
  timezone             String    @default("UTC")
  units                Units     @default(IMPERIAL)
  subscriptionTier     Tier      @default(FREE)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  trialEndsAt          DateTime?
  hadTrial             Boolean   @default(false)
  onboardingComplete   Boolean   @default(false)
  onboardingStep       Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  gardens           Garden[]
  collaborations    GardenCollaborator[]
  notificationPrefs NotificationPreference[]
  seedInventory     SeedInventory[]
  reminders         Reminder[]
  pushSubscriptions PushSubscription[]
  feedback          Feedback[]
  bedTemplates      BedTemplate[]
}

// ─── Bed templates ────────────────────────────────────────────────────────────

// A reusable bed plan: grid dimensions + a list of (row, col, plant) anchor
// assignments. userId null = curated built-in (seeded in migrations); set =
// a user's "save this bed as a template". Applying replays the assignments
// through the canonical assignPlant path (same shape as smart-layout).
model BedTemplate {
  id          String   @id @default(cuid())
  userId      String?
  name        String
  description String?
  gridCols    Int
  gridRows    Int
  cellSizeIn  Int
  createdAt   DateTime @default(now())

  user        User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments TemplateAssignment[]

  @@index([userId])
}

model TemplateAssignment {
  id         String @id @default(cuid())
  templateId String
  row        Int
  col        Int
  plantId    String

  template BedTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  plant    PlantLibrary @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

// ─── Feedback ─────────────────────────────────────────────────────────────────

// In-app feedback from alpha testers — one row per submission, mirrored to
// the owner's inbox by the submit action. `path` records where in the app
// the user was when they sent it.
model Feedback {
  id        String   @id @default(cuid())
  userId    String
  message   String
  path      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

// ─── Push Subscriptions ───────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dhKey String
  authKey   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Garden ───────────────────────────────────────────────────────────────────

model Garden {
  id              String   @id @default(cuid())
  userId          String
  name            String
  description     String?
  locationZip     String?
  locationDisplay String?
  usdaZone        String?
  lastFrostDate   String? // "MM-DD"
  firstFrostDate  String? // "MM-DD"
  widthFt         Float
  heightFt        Float
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  beds          Bed[]
  collaborators GardenCollaborator[]
  invitations   GardenInvitation[]
  seasons       Season[]
  weatherCache  WeatherCache?
  reminders     Reminder[]
  growthNotes   GrowthNote[]

  @@index([userId])
}

model GardenCollaborator {
  id         String     @id @default(cuid())
  gardenId   String
  userId     String
  role       CollabRole @default(VIEWER)
  invitedAt  DateTime   @default(now())
  acceptedAt DateTime?

  garden Garden @relation(fields: [gardenId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gardenId, userId])
  // gardenAccessFilter runs a collaborators.some({userId}) subquery on
  // nearly every request; the unique above has the wrong leading column.
  @@index([userId])
}

model GardenInvitation {
  id         String     @id @default(cuid())
  gardenId   String
  email      String
  role       CollabRole @default(VIEWER)
  token      String     @unique
  invitedAt  DateTime   @default(now())
  expiresAt  DateTime
  acceptedAt DateTime?

  garden Garden @relation(fields: [gardenId], references: [id], onDelete: Cascade)

  @@unique([gardenId, email])
}

// ─── Beds & Cells ─────────────────────────────────────────────────────────────

model Bed {
  id         String   @id @default(cuid())
  gardenId   String
  name       String
  xPosition  Float
  yPosition  Float
  widthFt    Float
  heightFt   Float
  gridCols   Int
  gridRows   Int
  cellSizeIn Int      @default(12)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  garden Garden @relation(fields: [gardenId], references: [id], onDelete: Cascade)
  cells  Cell[]

  @@index([gardenId])
}

model Cell {
  id       String   @id @default(cuid())
  bedId    String
  row      Int
  col      Int
  sunLevel SunLevel @default(FULL_SUN)
  notes    String?

  bed       Bed        @relation(fields: [bedId], references: [id], onDelete: Cascade)
  // Plantings where this is the PRIMARY (anchor) cell — used for rendering
  // labels and as the legacy single-cell relation. Most queries should use
  // `occupiedBy` instead to also catch footprint cells from multi-cell plants.
  plantings Planting[]
  // All plantings occupying this cell (primary or footprint). For "what's
  // growing in this cell?" this is the source of truth.
  occupiedBy PlantingCell[]

  @@unique([bedId, row, col])
}

// ─── Seasons ──────────────────────────────────────────────────────────────────

model Season {
  id        String    @id @default(cuid())
  gardenId  String
  name      String
  startDate DateTime
  endDate   DateTime?
  isActive  Boolean   @default(false)
  createdAt DateTime  @default(now())

  garden    Garden     @relation(fields: [gardenId], references: [id], onDelete: Cascade)
  plantings Planting[]

  @@index([gardenId, isActive])
}

// ─── Planting — central hub entity ───────────────────────────────────────────

model Planting {
  id                  String         @id @default(cuid())
  // The "primary" / anchor cell — where the plant label renders. For
  // multi-cell plants (tomato in a 6" grid, etc.) this is the cell the
  // user actually tapped; additional footprint cells live in the `cells`
  // relation. Kept here as a denormalized pointer so most existing queries
  // (which only care about the anchor) keep working unchanged.
  cellId              String
  seasonId            String
  plantId             String
  variety             String?
  status              PlantingStatus    @default(PLANNED)
  startMethod         PlantStartMethod?
  quantityPerCell     Int            @default(1)
  plantedDate         DateTime?
  transplantDate      DateTime?
  expectedHarvestDate DateTime?
  actualHarvestDate   DateTime?
  notes               String?
  rating              Int?
  growAgain           Boolean?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  // ── Occupancy window ────────────────────────────────────────────────────
  // Half-open interval [occupiesFrom, occupiesUntil) during which this
  // planting claims its PlantingCell footprint. Maintained EXCLUSIVELY via
  // lib/services/occupancy.ts — never write these fields ad hoc.
  // occupiesUntil null = open-ended (in-flight annuals, live perennials).
  occupiesFrom  DateTime  @default(now())
  occupiesUntil DateTime?
  // Perennial liveness: isPerennial denormalized from PlantLibrary at
  // creation (library edits never silently change occupancy); a live
  // perennial (clearedAt null) occupies its cells in EVERY season.
  isPerennial   Boolean   @default(false)
  clearedAt     DateTime?

  cell        Cell            @relation(fields: [cellId], references: [id], onDelete: Cascade)
  season      Season          @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  plant       PlantLibrary    @relation(fields: [plantId], references: [id])
  // All cells this planting occupies (the anchor + any footprint cells).
  // Invariant: exactly one entry per planting has isPrimary=true, and
  // that entry's cellId matches Planting.cellId above.
  cells       PlantingCell[]
  photos      PlantingPhoto[]
  harvestLogs HarvestLog[]
  growthNotes GrowthNote[]
  reminders   Reminder[]

  // The old @@unique([cellId, seasonId]) is GONE — the time model allows
  // successive plantings in one cell within a season when their occupancy
  // windows don't overlap. The overlap rule is enforced in resolveFootprint
  // inside the assign transaction under a per-bed advisory lock.
  @@index([cellId, seasonId])
  @@index([seasonId])
  @@index([plantId])
  @@index([isPerennial, clearedAt])
}

// Join table linking a Planting to every Cell in its footprint.
//
// A single-cell plant (lettuce in 12" cells, spacingInches ~= cellSizeIn)
// has one PlantingCell entry with isPrimary=true.
//
// A multi-cell plant (tomato in 6" cells, spacingInches=18) has multiple
// entries — one isPrimary=true at the anchor, and additional non-primary
// entries for each footprint cell.
//
// "One planting per cell per season" is enforced in application code
// (assignPlant) since Prisma can't express that across this relation.
model PlantingCell {
  plantingId String
  cellId     String
  isPrimary  Boolean @default(false)

  planting Planting @relation(fields: [plantingId], references: [id], onDelete: Cascade)
  cell     Cell     @relation(fields: [cellId], references: [id], onDelete: Cascade)

  @@id([plantingId, cellId])
  @@index([cellId])
}

// A journal entry — either about one planting OR about the garden as a
// whole ("aphids on the east bed").
//
// Exactly one of plantingId/gardenId is set. Prisma can't express that
// XOR, so it's enforced in application code (addGrowthNote sets only
// plantingId; addGardenNote sets only gardenId).
model GrowthNote {
  id         String   @id @default(cuid())
  plantingId String?
  gardenId   String?
  body       String
  createdAt  DateTime @default(now())

  planting Planting? @relation(fields: [plantingId], references: [id], onDelete: Cascade)
  garden   Garden?   @relation(fields: [gardenId], references: [id], onDelete: Cascade)

  @@index([plantingId])
  @@index([gardenId])
}

model HarvestLog {
  id          String   @id @default(cuid())
  plantingId  String
  harvestedAt DateTime @default(now())
  quantity    Float
  unit        String
  notes       String?
  // Client-generated idempotency key — offline-queued logs replay safely
  // (a duplicate insert is treated as success, never a second row).
  clientId    String?  @unique

  planting Planting @relation(fields: [plantingId], references: [id], onDelete: Cascade)

  @@index([plantingId, harvestedAt])
}

model PlantingPhoto {
  id         String   @id @default(cuid())
  plantingId String
  url        String
  caption    String?
  takenAt    DateTime @default(now())

  planting Planting @relation(fields: [plantingId], references: [id], onDelete: Cascade)

  @@index([plantingId])
}

// ─── Plant Library ────────────────────────────────────────────────────────────

model PlantLibrary {
  id               String        @id @default(cuid())
  externalId       String?       @unique
  source           String?
  name             String
  scientificName   String?
  commonNames      String[]
  category         PlantCategory
  plantFamily      String?
  description      String?
  imageUrl         String?
  daysToMaturity   Int?
  spacingInches    Int?
  plantingDepthIn  Float?
  sunRequirement   SunLevel?
  waterRequirement WaterNeed?
  soilPhRange      String?
  plantingSeasons  String[]
  indoorStartWeeks Int?
  transplantWeeks  Int?
  harvestMonths    String[]
  // True when timing fields were filled from category-based estimates
  // (e.g. an imported plant the source API had no grow-cycle data for),
  // so the UI can label them and a user edit can clear the flag.
  timingEstimated  Boolean       @default(false)
  // Persists across seasons (asparagus, herbs, berries, trees). Copied onto
  // Planting.isPerennial at assign time so occupancy never shifts under a
  // library edit.
  isPerennial      Boolean       @default(false)
  // Common pests/diseases for this plant. Persisted values come from
  // Perenual enrichment (pest_susceptibility); the UI also merges in
  // category-based defaults from lib/services/pest-data.ts, so these may
  // be empty for curated/seed plants and still render useful info.
  commonPests      String[]
  commonDiseases   String[]
  customForUserId  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  companions          CompanionRelation[]  @relation("PlantCompanions")
  antagonists         CompanionRelation[]  @relation("PlantAntagonists")
  plantings           Planting[]
  seedInventory       SeedInventory[]
  templateAssignments TemplateAssignment[]

  @@index([customForUserId])
  @@index([category])
}

model CompanionRelation {
  id        String        @id @default(cuid())
  plantId   String
  relatedId String
  type      CompanionType
  notes     String?

  plant   PlantLibrary @relation("PlantCompanions", fields: [plantId], references: [id], onDelete: Cascade)
  related PlantLibrary @relation("PlantAntagonists", fields: [relatedId], references: [id], onDelete: Cascade)

  @@unique([plantId, relatedId, type])
  @@index([relatedId])
}

// ─── Reminders & Notifications ────────────────────────────────────────────────

model Reminder {
  id             String       @id @default(cuid())
  userId         String
  plantingId     String?
  gardenId       String?
  type           ReminderType
  title          String
  body           String?
  scheduledAt    DateTime
  sentAt         DateTime?
  dismissed      Boolean      @default(false)
  recurring      Boolean      @default(false)
  recurrenceCron String?
  sendAttempts   Int          @default(0)

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  planting Planting? @relation(fields: [plantingId], references: [id], onDelete: SetNull)
  garden   Garden?   @relation(fields: [gardenId], references: [id], onDelete: SetNull)

  // Bell + reminders page: filtered by user/dismissed, ordered by scheduledAt.
  @@index([userId, dismissed, scheduledAt])
  // Hourly cron scan: sentAt IS NULL AND scheduledAt <= now.
  @@index([sentAt, scheduledAt])
  // Per-planting dedupe/cleanup and frost-alert dup checks.
  @@index([plantingId])
  @@index([gardenId])
}

model NotificationPreference {
  id           String       @id @default(cuid())
  userId       String
  type         ReminderType
  enabled      Boolean      @default(true)
  channelEmail Boolean      @default(true)
  channelPush  Boolean      @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

// ─── Weather Cache ────────────────────────────────────────────────────────────

model WeatherCache {
  id        String   @id @default(cuid())
  gardenId  String   @unique
  current   Json
  forecast  Json?
  // Last time the refresh cron observed rain-ish current conditions for
  // this garden — drives the "skip watering, it rained" heuristic.
  lastRainAt DateTime?
  updatedAt DateTime @updatedAt

  garden Garden @relation(fields: [gardenId], references: [id], onDelete: Cascade)
}

// ─── Seed Inventory ───────────────────────────────────────────────────────────

model SeedInventory {
  id          String    @id @default(cuid())
  userId      String
  plantId     String
  variety     String    @default("")
  quantity    Int       @default(0)
  unit        String    @default("packets")
  purchasedAt DateTime?
  expiresAt   DateTime?
  notes       String?

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  plant PlantLibrary @relation(fields: [plantId], references: [id])

  @@unique([userId, plantId, variety])
  @@index([plantId])
}

// Processed Stripe webhook events, keyed by Stripe's event id. The webhook
// handler inserts a row before processing; a duplicate insert (Stripe retries
// and can deliver the same event more than once) signals "already handled" so
// we skip reprocessing.
model WebhookEvent {
  id          String   @id // Stripe event id (evt_...)
  type        String
  processedAt DateTime @default(now())
}
